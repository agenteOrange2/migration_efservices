APP_NAME=Laravel
APP_ENV=local  # PRODUCTION: Set to 'production'
APP_KEY=
APP_DEBUG=true  # PRODUCTION: Set to 'false'
APP_TIMEZONE=UTC
APP_URL=http://localhost  # PRODUCTION: Set to your domain with HTTPS

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug  # PRODUCTION: Set to 'warning' or 'error' to reduce log verbosity

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=redis  # Use redis for better performance (database for development)
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis  # Use redis for better performance (database for development)

CACHE_STORE=redis
CACHE_PREFIX=laravel_cache

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PREFIX=laravel_database_
REDIS_TIMEOUT=5
REDIS_READ_TIMEOUT=10

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Support email for audit trail (receives CC of employment verification emails)
SUPPORT_EMAIL="support@efcts.com"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Security Configuration
API_RATE_LIMIT=60
API_RATE_DECAY=1
AUTH_RATE_LIMIT=5
AUTH_RATE_DECAY=1
UPLOAD_RATE_LIMIT=20
UPLOAD_RATE_DECAY=1

# File Upload Security
MAX_FILE_SIZE=10240
SCAN_UPLOADS=true  # CRITICAL: Must be true in production to scan uploaded files for malware

# Token Expiration (minutes)
EMAIL_VERIFICATION_EXPIRY=1440
VEHICLE_VERIFICATION_EXPIRY=10080
EMPLOYMENT_VERIFICATION_EXPIRY=10080
PASSWORD_RESET_EXPIRY=60
REFERRER_TOKEN_EXPIRY=43200

# Session Security
SESSION_SECURE_COOKIE=true  # CRITICAL: Must be true in production (HTTPS only)
SESSION_SAME_SITE=lax  # Use 'strict' for higher security, 'lax' for better compatibility

# Password Requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=false

# Two-Factor Authentication
2FA_ENABLED=true  # Enable 2FA support
2FA_REQUIRED_ADMIN=true  # RECOMMENDED: Force 2FA for admin users in production

# Audit Logging
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_CHANNEL=daily

# Failed Login Protection
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION=15
NOTIFY_ADMIN_FAILED_LOGINS=true
